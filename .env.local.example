# ─── Database ─────────────────────────────────────────────────────────
# Prisma connection string (Supabase connection pooler)
DATABASE_URL=
# Direct connection for migrations (bypasses pooler)
DIRECT_DATABASE_URL=

# ─── Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis (BullMQ + caching) ────────────────────────────────────────
REDIS_URL=

# ─── LLM ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Transcription ────────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ─── Social Platforms ─────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# ─── Billing ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKER_CONCURRENCY=

# ─── Dev Mock Mode ───────────────────────────────────────────────────
# MOCK_AI=true        → LLM calls return fixture data (no Anthropic cost)
# DEV_NO_EXTERNAL_APIS=true → Blocks ALL paid APIs (Anthropic, AssemblyAI, Replicate)
# Use both for fully offline local development.
MOCK_AI=false
DEV_NO_EXTERNAL_APIS=false

# ─── Dev Auth Bypass ──────────────────────────────────────────────────
# Set to true to skip Supabase Auth entirely in development.
# Creates a fake dev user so you can test the full pipeline locally.
# NEVER set this in production.
DEV_AUTH_BYPASS=false
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_EMAIL=dev@localhost
