# === VERTICAL SLICE (minimum to run) ===

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:6543/postgres?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (BullMQ) — Upstash or local
REDIS_URL=redis://localhost:6379

# Anthropic (analyze worker — clip scoring + text generation)
ANTHROPIC_API_KEY=

# Transcription — AssemblyAI by default, set to 'whisper' for Modal.com
TRANSCRIPTION_ENGINE=assemblyai
ASSEMBLYAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === OPTIONAL — Whisper via Modal.com ===
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# === PHASE 5 — Billing (not needed for vertical slice) ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_CREATOR=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_BUSINESS=

# === PHASE 5 — Social OAuth (not needed for vertical slice) ===
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_API_KEY=
# X_API_SECRET=
# X_BEARER_TOKEN=

# === Dev helpers ===
# DEV_USER_ID=              # Your Supabase auth.users UUID, for seed script
# DEV_USER_EMAIL=           # Email for dev profile
