    "db:seed-dev": "tsx scripts/seed-dev.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@prisma/client": "5.22.0",
    "@supabase/ssr": "^0.9.0",
    "archiver": "^7.0.1",
    "assemblyai": "4.8.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "5.25.6",
    "clsx": "^2.1.1",
    "googleapis": "^144.0.0",
    "ioredis": "5.4.2",
    "next": "14.2.35",
    "pdf-parse": "^2.4.5",
    "react": "^18",
    "react-dom": "^18",
    "replicate": "1.0.1",
    "stripe": "^20.4.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "yt-dlp-wrap": "2.3.12",
    "zod": "3.24.1"
