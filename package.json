{
  "name": "originclipai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "next lint && prettier --check .",
    "lint:fix": "next lint --fix && prettier --write .",
    "typecheck": "tsc --noEmit",
    "workers": "tsx --env-file=.env.local src/workers/index.ts",
    "workers:dev": "tsx watch --env-file=.env.local src/workers/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-dev": "tsx scripts/seed-dev.ts",
    "db:seed-demo": "tsx --env-file=.env.local scripts/seed-demo.ts",
    "db:studio": "prisma studio",
    "render-clip": "tsx scripts/render-clip.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@base-ui/react": "^1.3.0",
