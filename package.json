    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "4.19.2",
    "typescript": "^5",
    "vitest": "2.1.8"
  }
